[alias]
    amend = commit --amend
    br = branch
    co = checkout
    c = commit
    d = diff
    fix = "!f() { rev=${1:-$(git rev-parse HEAD)}; git commit -a --fixup=${rev} && git rebase -i ${rev}~1 --autosquash; }; f"
    graph = log --graph --oneline --decorate --date=relative --all
    rb = rebase
    rba = rebase --abort
    rbc = rebase --continue
    st = status
[push]
	default = simple
[pull]
    rebase = true
[core]
    autocrlf = input
    editor = vim
	excludesfile = ~/.gitignore
	preloadindex = true
[filter "gitignore"]
    clean = "sed '/#gitignore$/'d"
    smudge = cat
[color]
	branch = auto
	diff = auto
	status = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[gc]
	auto = 256
